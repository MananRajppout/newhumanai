# Template for Railway env vars - placeholders only
# Your actual values are in backend/.env (which is gitignored)
# In Railway: Variables tab → Raw Editor → paste contents of your .env

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...
DEEPGRAM_API_KEY=...
OPENAI_API_KEY=sk-proj-...
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
PORT=3000

# AGENT service ONLY also needs:
# BACKEND_URL=https://your-api-service.up.railway.app
