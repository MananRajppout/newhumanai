{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://CHANGE-ME-TO-YOUR-DEPLOYED-BACKEND.example.com"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://CHANGE-ME-TO-YOUR-DEPLOYED-BACKEND.example.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
